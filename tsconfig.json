{
  "compilerOptions": {
    "target": "ES2023",
    "module": "CommonJS",        // Node.js compatible
    "moduleResolution": "node",  // Standard Node resolution
    "outDir": "./dist",          // Relative path
    "rootDir": "./src",          // Your source folder
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}